@model IEnumerable<Practice_Project.Models.StudentVm>

@{
    ViewData["Title"] = "Students List";
}

<h2>Students List</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Add New Student</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Roll Number</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Semester</th>
                <th>Section</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var student in Model)
                {
                    <tr>
                        <td>@student.StudentId</td>
                        <td>@student.Name</td>
                        <td>@student.RollNumber</td>
                        <td>@student.Email</td>
                        <td>@student.Phone</td>
                        <td>Semester @student.Semester</td>
                        <td>@student.Section</td>
                        <td>
                            @if (student.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@student.StudentId" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Index" asp-route-id="@student.StudentId" class="btn btn-sm btn-info">Details</a>
                            <a asp-action="Delete" asp-route-id="@student.StudentId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center">
                        <div class="alert alert-info">
                            No students found. <a asp-action="Create">Add your first student</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>