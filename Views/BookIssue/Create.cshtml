@model Practice_Project.Models.BookIssueViewModel

@{
    ViewData["Title"] = "Issue New Book";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Issue New Book</h4>
                </div>
                <div class="card-body">
                    
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <!-- Book Selection -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="BookId" class="form-label fw-bold">Select Book *</label>
                                    @if (ViewBag.Books != null)
                                    {
                                        <select asp-for="BookId" class="form-select" asp-items="ViewBag.Books">
                                            <option value="">-- Select Book --</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning p-2">
                                            <i class="fas fa-exclamation-triangle me-2"></i>
                                            No books available. 
                                            <a asp-controller="Book" asp-action="Create" class="alert-link">Add books first</a>
                                        </div>
                                        <select asp-for="BookId" class="form-select" disabled>
                                            <option value="">No books available</option>
                                        </select>
                                    }
                                    <span asp-validation-for="BookId" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="StudentId" class="form-label fw-bold">Select Student *</label>
                                    @if (ViewBag.Students != null)
                                    {
                                        <select asp-for="StudentId" class="form-select" asp-items="ViewBag.Students">
                                            <option value="">-- Select Student --</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning p-2">
                                            <i class="fas fa-exclamation-triangle me-2"></i>
                                            No students available. 
                                            <a asp-controller="Student" asp-action="Create" class="alert-link">Register students first</a>
                                        </div>
                                        <select asp-for="StudentId" class="form-select" disabled>
                                            <option value="">No students available</option>
                                        </select>
                                    }
                                    <span asp-validation-for="StudentId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Dates Section -->
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="IssueDate" class="form-label fw-bold">Issue Date *</label>
                                    <input asp-for="IssueDate" class="form-control" type="date" />
                                    <span asp-validation-for="IssueDate" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="DueDate" class="form-label fw-bold">Due Date *</label>
                                    <input asp-for="DueDate" class="form-control" type="date" />
                                    <span asp-validation-for="DueDate" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="Quantity" class="form-label fw-bold">Quantity *</label>
                                    <input asp-for="Quantity" class="form-control" type="number" min="1" max="10" value="1" />
                                    <span asp-validation-for="Quantity" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Status and Return Date -->
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="Status" class="form-label fw-bold">Status *</label>
                                    <select asp-for="Status" class="form-select">
                                        <option value="Issued">Issued</option>
                                        <option value="Returned">Returned</option>
                                        <option value="Overdue">Overdue</option>
                                        <option value="Lost">Lost</option>
                                        <option value="Damaged">Damaged</option>
                                    </select>
                                    <span asp-validation-for="Status" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="ReturnDate" class="form-label fw-bold">Return Date</label>
                                    <input asp-for="ReturnDate" class="form-control" type="date" />
                                    <span asp-validation-for="ReturnDate" class="text-danger"></span>
                                    <small class="form-text text-muted">Leave empty if book is not returned yet</small>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="FineAmount" class="form-label fw-bold">Fine Amount</label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="FineAmount" class="form-control" type="number" step="0.01" min="0" value="0" />
                                    </div>
                                    <span asp-validation-for="FineAmount" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Remarks -->
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label asp-for="Remarks" class="form-label fw-bold">Remarks</label>
                                    <textarea asp-for="Remarks" class="form-control" rows="3" placeholder="Enter any additional remarks..."></textarea>
                                    <span asp-validation-for="Remarks" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="form-group">
                            <div class="d-flex justify-content-between">
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-2"></i>Back to List
                                </a>
                                
                                <button type="submit" class="btn btn-primary px-4" 
                                        @(ViewBag.Books == null || ViewBag.Students == null ? "disabled" : "")>
                                    <i class="fas fa-book-medical me-2"></i>Issue Book
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
                
                <div class="card-footer bg-light">
                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                * Required fields
                            </small>
                        </div>
                        <div class="col-md-6 text-end">
                            <small class="text-muted">
                                <i class="fas fa-clock me-1"></i>
                                Default lending period: 14 days
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Set default dates
            const issueDateInput = document.getElementById('IssueDate');
            const dueDateInput = document.getElementById('DueDate');
            
            if (issueDateInput && !issueDateInput.value) {
                const today = new Date().toISOString().split('T')[0];
                issueDateInput.value = today;
            }
            
            if (dueDateInput && !dueDateInput.value) {
                const dueDate = new Date();
                dueDate.setDate(dueDate.getDate() + 14);
                dueDateInput.value = dueDate.toISOString().split('T')[0];
            }
            
            // Auto-calculate fine if overdue
            const statusSelect = document.getElementById('Status');
            const fineAmountInput = document.getElementById('FineAmount');
            
            if (statusSelect && fineAmountInput) {
                statusSelect.addEventListener('change', function() {
                    if (this.value === 'Overdue' && fineAmountInput.value === '0') {
                        // Auto-calculate fine (example: $1 per day for 7 days)
                        fineAmountInput.value = '7.00';
                    }
                });
            }
            
            // Show/hide return date based on status
            const returnDateInput = document.getElementById('ReturnDate');
            
            if (statusSelect && returnDateInput) {
                function updateReturnDateField() {
                    if (statusSelect.value === 'Returned' && !returnDateInput.value) {
                        const today = new Date().toISOString().split('T')[0];
                        returnDateInput.value = today;
                    }
                }
                
                statusSelect.addEventListener('change', updateReturnDateField);
                updateReturnDateField(); // Initial check
            }
            
            // Disable submit button if no data
            const submitButton = document.querySelector('button[type="submit"]');
            const bookSelect = document.querySelector('select[name="BookId"]');
            const studentSelect = document.querySelector('select[name="StudentId"]');
            
            if (submitButton) {
                const isDisabled = !bookSelect || bookSelect.disabled || 
                                 !studentSelect || studentSelect.disabled ||
                                 bookSelect.options.length <= 1 || 
                                 studentSelect.options.length <= 1;
                
                if (isDisabled) {
                    submitButton.disabled = true;
                    submitButton.title = "Please add books and students first";
                    submitButton.classList.add('disabled');
                }
            }
            
            // Quantity validation
            const quantityInput = document.getElementById('Quantity');
            if (quantityInput) {
                quantityInput.addEventListener('input', function() {
                    if (this.value < 1) this.value = 1;
                    if (this.value > 10) this.value = 10;
                });
            }
        });
    </script>
    
    <style>
        .card {
            border-radius: 10px;
            border: none;
        }
        
        .card-header {
            border-radius: 10px 10px 0 0 !important;
        }
        
        .form-label {
            color: #495057;
        }
        
        .btn-primary {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }
        
        .btn-primary:hover {
            background-color: #0b5ed7;
            border-color: #0a58ca;
        }
        
        .alert a {
            text-decoration: none;
            font-weight: 600;
        }
        
        select.form-select:disabled {
            background-color: #e9ecef;
            cursor: not-allowed;
        }
        
        button:disabled {
            cursor: not-allowed;
            opacity: 0.65;
        }
    </style>
}